<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net8.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <LangVersion>latest</LangVersion>
  </PropertyGroup>

  <!--
    默认按以下相对路径引用 PenguinTools.Core：
      ../PenguinTools/PenguinTools.Core/PenguinTools.Core.csproj
    如你的目录不同，可手动修改 Include 路径。
  -->
  <ItemGroup>
    <ProjectReference Include="..\..\..\PenguinTools\PenguinTools.Core\PenguinTools.Core.csproj"
                      Condition="Exists('..\..\..\PenguinTools\PenguinTools.Core\PenguinTools.Core.csproj')" />
  </ItemGroup>
</Project>

